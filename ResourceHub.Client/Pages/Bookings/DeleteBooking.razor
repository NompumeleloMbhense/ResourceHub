@page "/bookings/delete/{id:int}"
@using ResourceHub.Client.Services
@using ResourceHub.Shared.DTOs

@inject IBookingService BookingService
@inject NavigationManager Navigation

<h3 class="page-title">Delete Booking</h3>

@if (booking == null)
{
    <p>Loading...</p>
}
else
{
    <div class="form-container">
        <p class="warning">Are you sure you want to delete this booking?</p>

        <div class="booking-summary">
            <h4>@booking.ResourceName</h4>
            <p><strong>Booked By:</strong> @booking.BookedBy</p>
            <p><strong>Purpose:</strong> @booking.Purpose</p>
            <p><strong>Start:</strong> @booking.StartTime.ToString("f")</p>
            <p><strong>End:</strong> @booking.EndTime.ToString("f")</p>
        </div>

        <div class="actions">
            <button class="btn danger" @onclick="Delete">Delete</button>
            <button class="btn secondary" @onclick="Cancel">Cancel</button>
        </div>

        @if (!string.IsNullOrEmpty(error))
        {
            <p class="error">@error</p>
        }
    </div>
}

@code {
    [Parameter] public int Id { get; set; }

    private BookingDto? booking;
    private string? error;

    protected override async Task OnInitializedAsync()
    {
        booking = await BookingService.GetBookingByIdAsync(Id);
    }

    private async Task Delete()
    {
        var success = await BookingService.DeleteBookingAsync(Id);

        if (success)
        {
            Navigation.NavigateTo("/bookings", forceLoad: true);
        }
        else
        {
            error = "Failed to delete booking";
        }
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/bookings");
    }
}