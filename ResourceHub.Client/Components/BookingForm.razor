@using ResourceHub.Shared.Forms
@using ResourceHub.Shared.DTOs

<EditForm Model="Model" OnValidSubmit="HandleSubmit">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <!-- Resource -->
    <div class="form-group">
        <label>Resource</label>
        <InputSelect @bind-Value="Model.ResourceId" class="input">
            <option value="0">-- Select Resource --</option>
            @foreach (var r in Resources)
            {
                <option value="@r.Id">@r.Name</option>
            }
        </InputSelect>
    </div>

    <!-- Booked By -->
    <div class="form-group">
        <label>Booked By</label>
        <InputText @bind-Value="Model.BookedBy" class="input" />
    </div>

    <!-- Purpose -->
    <div class="form-group">
        <label>Purpose</label>
        <InputText @bind-Value="Model.Purpose" class="input" />
    </div>

    <!-- Start -->
    <div class="form-group">
        <label>Start Time</label>
        <input type="datetime-local"
                value="@StartTimeString"
                @onchange="OnStartChanged"
                class="input" />
    </div>

    <!-- End -->
    <div class="form-group">
        <label>End Time</label>
        <input type="datetime-local"
                value="@EndTimeString"
                @onchange="OnEndChanged"
                class="input" />
    </div>

    <button type="submit" class="btn" disabled="@isSubmitting">
        @SubmitText
    </button>

    <button type="button" class="btn secondary" @onclick="OnCancel">
        Cancel
    </button>
</EditForm>

@if (!string.IsNullOrEmpty(error))
{
    <p class="error">@error</p>
}


@code
{
    [Parameter] public BookingFormModel Model { get; set; } = default!;

    [Parameter] public List<ResourceDto> Resources { get; set; } = new();

    [Parameter] public EventCallback<BookingFormModel> OnSubmit { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    [Parameter] public string SubmitText { get; set; } = "Save";
    
    private bool isSubmitting = false;

    private string? error;

    private string StartTimeString =>
    Model.StartTime == default
        ? ""
        : Model.StartTime.ToString("yyyy-MM-ddTHH:mm");

    private string EndTimeString =>
    Model.EndTime == default
        ? ""
        : Model.EndTime.ToString("yyyy-MM-ddTHH:mm");


    private async Task HandleSubmit()
    {
        error = null;

        if (Model.EndTime <= Model.StartTime)
        {
            error = "End time must be after start time";
            return;
        }

        isSubmitting = true;
        await OnSubmit.InvokeAsync(Model);
        isSubmitting = false;
    }

    private void OnStartChanged(ChangeEventArgs e)
    {
        if (DateTime.TryParse(e.Value?.ToString(), out var date))
        {
            Model.StartTime = date;
        }
    }

    private void OnEndChanged(ChangeEventArgs e)
    {
        if (DateTime.TryParse(e.Value?.ToString(), out var date))
        {
            Model.EndTime = date;
        }
    }
}